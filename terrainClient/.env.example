# 思极地图开放平台申请的密钥
VITE_EPGIS_APP_KEY=your_app_key
VITE_EPGIS_APP_SECRET=your_app_secret

# 思极地图 JS SDK（v3+）
VITE_EPGIS_SDK_URL=https://map.sgcc.com.cn/maps?v=3.1.0

# 底图样式（需 SDK 3.0+）
VITE_EPGIS_MAP_STYLE=aegis://styles/aegis/Satellite512

# 地形数据源：local（本地 terrain-server，默认）| official（官网 aegis.Terrain3D，需数据权限）
VITE_TERRAIN_SOURCE=local

# 本地 GEM Terrain-RGB 瓦片（开发走 Vite 代理 /terrain → localhost:8080）
VITE_TERRAIN_TILE_URL=/terrain/{z}/{x}/{y}.png
VITE_TERRAIN_MAX_ZOOM=10
VITE_TERRAIN_EXAGGERATION=2.5

# 官网三维地形（VITE_TERRAIN_SOURCE=official 时使用）
# VITE_TERRAIN_URL=aegis://aegis.Terrain3D
